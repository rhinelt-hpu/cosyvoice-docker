# CosyVoice Docker Configuration

# Service port (check availability before setting)
PORT=8188

# Model to use (default: Fun-CosyVoice3-0.5B - latest and best performance)
MODEL_NAME=Fun-CosyVoice3-0.5B
MODEL_DIR=pretrained_models/Fun-CosyVoice3-0.5B

# vLLM and concurrency settings
NUM_GPUS=1                       # Number of GPUs to use (1 = single GPU, 2+ = multi-GPU data parallel)
MAX_CONCURRENT=4                 # Maximum concurrent inference requests (beyond this, requests queue)
GPU_MEMORY_UTILIZATION=0.5       # GPU memory fraction for vLLM KV cache (0.2-0.9)

# GPU idle timeout in seconds (release GPU memory after idle)
GPU_IDLE_TIMEOUT=600
